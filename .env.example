# Copy to .env.local for local dev. On AWS Amplify, set these in
# App settings → Environment variables (NOT committed to git).

# ── Server-side (secret — never exposed to the browser) ──────────────────────
# Base URL of the Resume Parser backend admin API, e.g. https://api.your-domain.com
BACKEND_API_URL=http://localhost:8000
# Shared secret sent as X-Admin-Token; must match the backend's ADMIN_API_TOKEN
ADMIN_API_TOKEN=
# Operator emails (comma-separated) allowed into the platform Admin dashboard
# (/dashboard/admin). These accounts see every customer's aggregate usage, so
# keep the list tight. Leave empty to disable the Admin area entirely.
ADMIN_EMAILS=

# ── Public (inlined into the client bundle at build time) ────────────────────
# Cognito IDs — public identifiers, used by both the browser SDK and
# server-side token verification.
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
# Public API base URL shown in /docs samples (optional; defaults to the
# deployed Lambda URL when unset).
NEXT_PUBLIC_API_BASE_URL=
